# Copy to `.env.local` for local dev.
# In Vercel → Project → Settings → Environment Variables, set the same keys for Production (and Preview if needed).

# -----------------------------------------------------------------------------
# Vercel (Next.js frontend)
# -----------------------------------------------------------------------------
# The API lives in a separate repo (backend-only): https://github.com/enquiries-dcrs/dcrs-backend
# If this Next app lives in the monorepo (DCRS-App), set Vercel Root Directory to `frontend`.

# -----------------------------------------------------------------------------
# Render (Express API) — must match what you set here
# -----------------------------------------------------------------------------
# Public base URL of the API (no trailing slash), e.g. https://dcrs-backend.onrender.com
NEXT_PUBLIC_API_URL=

# -----------------------------------------------------------------------------
# Supabase (browser client)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Dashboard → Authentication → URL configuration:
#   Site URL: your Vercel production URL (e.g. https://your-app.vercel.app)
#   Redirect URLs: include https://your-app.vercel.app/auth/callback (and preview URLs if you use them)

# -----------------------------------------------------------------------------
# Render backend env (set on the web service, not in Vercel)
# -----------------------------------------------------------------------------
# FRONTEND_URL = same Vercel production URL as above (no trailing slash). Used for
#   invite emails, auth callback base, and CORS when combined with defaults.
# CORS_ORIGINS = optional comma-separated extra allowed origins (e.g. alternate domains).
# CORS_ALLOW_VERCEL_PREVIEWS = true  → allow any https://*.vercel.app origin (see backend/render.yaml).
